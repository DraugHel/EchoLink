# Kopieren nach .env und Werte setzen. .env wird beim Start automatisch geladen
# (server/loadEnv.js); Variablen aus PM2/Umgebung haben Vorrang.
# WICHTIG: .env NIEMALS committen oder in Zips packen.

SESSION_SECRET=hier-langen-zufallsstring-rein
ECHO_API_KEY=hier-api-key-rein

# Agent Mode: erlaubte User-IDs, kommagetrennt
ECHOLINK_DIR=/root/echolink

# Externe Briefings landen in dieser Conversation
BRIEFING_CONVERSATION_ID=65

DEFAULT_MODEL=glm-5.1:cloud

# Mehrzeilige Werte muessen in doppelte Anfuehrungszeichen:
# DEFAULT_SYSTEM_PROMPT="Zeile 1
# Zeile 2"

# Lokaler MCP-Web-Dienst. Der Dienst bindet ausschließlich an 127.0.0.1.
# active: MCP zuerst, direkter SearXNG-/Firecrawl-Fallback bei MCP-Ausfall.
# direct: MCP-Ausführung abschalten und nur die bisherigen direkten Tools nutzen.
MCP_WEB_MODE=active
MCP_WEB_URL=http://127.0.0.1:3011/mcp
MCP_WEB_REQUEST_TIMEOUT_MS=20000
# Optional getrennte Timeouts pro Registry-Tool.
# MCP_WEB_SEARCH_TIMEOUT_MS=20000
# MCP_WEB_SCRAPE_TIMEOUT_MS=20000
MCP_WEB_FALLBACK_COOLDOWN_MS=15000
# MCP_REGISTRY_DISCOVERY_CACHE_MS=10000
# MCP_WEB_TOKEN ist optional; ohne eigenen Wert wird SESSION_SECRET verwendet.
# MCP_WEB_TOKEN=hier-langen-zufallsstring-rein

# Read-only Reddit-Reader fuer Links aus Chat und firecrawl_scrape.
# App unter https://www.reddit.com/prefs/apps als "script" anlegen.
# Zugangsdaten bleiben ausschliesslich serverseitig in .env.
REDDIT_READER_MODE=disabled
# REDDIT_CLIENT_ID=...
# REDDIT_CLIENT_SECRET=...
# REDDIT_USER_AGENT=linux:echolink:v1.0 (by /u/dein_reddit_name)

# Offizieller Remote-GitHub-MCP-Server. Standardmäßig deaktiviert.
# Aktivierung erst nach Eintragen eines Fine-grained PAT mit minimalen Leserechten.
# EchoLink erzwingt X-MCP-Readonly, Lockdown und eine feste Tool-Allowlist.
GITHUB_MCP_MODE=disabled
GITHUB_MCP_URL=https://api.githubcopilot.com/mcp/
# GITHUB_MCP_TOKEN=github_pat_...
GITHUB_MCP_ALLOWED_REPOS=DraugHel/EchoLink
GITHUB_MCP_REQUEST_TIMEOUT_MS=30000
GITHUB_MCP_TOOL_TIMEOUT_MS=30000
GITHUB_MCP_FALLBACK_COOLDOWN_MS=30000

# Offizieller Microsoft Playwright MCP Server v0.0.78 im isolierten
# read-only Docker-Container. Standardmäßig deaktiviert.
# Exakte Origins mit Semikolon trennen; keine Wildcards verwenden.
# Der Standard erlaubt ausschließlich EchoLink auf dem lokalen Port.
MCP_PLAYWRIGHT_MODE=disabled
MCP_PLAYWRIGHT_URL=http://127.0.0.1:3012/mcp
MCP_PLAYWRIGHT_ALLOWED_ORIGINS=http://127.0.0.1:3000
MCP_PLAYWRIGHT_REQUEST_TIMEOUT_MS=20000
MCP_PLAYWRIGHT_TOOL_TIMEOUT_MS=20000
MCP_PLAYWRIGHT_FALLBACK_COOLDOWN_MS=15000
