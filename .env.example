# Kopieren nach .env und Werte setzen. .env wird beim Start automatisch geladen
# (server/loadEnv.js); Variablen aus PM2/Umgebung haben Vorrang.
# WICHTIG: .env NIEMALS committen oder in Zips packen.

SESSION_SECRET=hier-langen-zufallsstring-rein
ECHO_API_KEY=hier-api-key-rein

# Agent Mode: erlaubte User-IDs, kommagetrennt
ECHOLINK_DIR=/root/echolink

# Externe Briefings landen in dieser Conversation
BRIEFING_CONVERSATION_ID=65

DEFAULT_MODEL=glm-5.1:cloud

# Mehrzeilige Werte muessen in doppelte Anfuehrungszeichen:
# DEFAULT_SYSTEM_PROMPT="Zeile 1
# Zeile 2"
